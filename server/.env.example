PORT=3000
JWT_SECRET=your-secret-key-change-this-to-something-random
ADMIN_EMAIL=admin@duguud.com
ADMIN_PASSWORD=change-this-to-a-strong-password

# PayFast — get yours at https://www.payfast.co.za/
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYFAST_MODE=sandbox   # switch to 'live' when ready

# Email (SMTP) — for order confirmations. Skip if not ready — no emails sent.
# For domains.co.za Email Only plans, the SMTP host is typically mail.yourdomain.co.za
# In DirectAdmin, go to E-mail Accounts > click on your email > Connection Details
SMTP_HOST=mail.duguud.co.za
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=admin@duguud.co.za
SMTP_PASS=your-email-password
SMTP_FROM=DuGuud <noreply@duguud.co.za>
